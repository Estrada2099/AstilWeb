---
import ProductLandingLayout from "../../layouts/ProductLandingLayout.astro";
---

<ProductLandingLayout
  title="Nombre del producto"
  description="Descripción breve orientada al comprador B2B: problema que resuelve, tipo de operación y beneficio principal."
>
  <section class="section">
    <div class="section-inner">
      <p class="eyebrow">Producto</p>
      <h2>Propuestá de valor especifica</h2>
      <p class="lead">
        Esta plantilla está lista para duplicarse como landing page estatica dentro de
        <code>src/pages/productos</code>. Cambia textos, agrega secciones y conserva el layout
        para mantener consistencia con la marca.
      </p>
    </div>
  </section>
</ProductLandingLayout>
