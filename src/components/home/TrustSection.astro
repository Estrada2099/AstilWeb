---
import { proof } from "../../data/site";
---

<section class="section intro" id="confianza">
  <div class="section-inner intro__grid">
    <div>
      <p class="eyebrow">Confianza tecnica</p>
      <h2>Respaldo medible para decisiones industriales.</h2>
    </div>
    <div class="intro__copy">
      <p>
        Astil Basculas es una empresa mexicana especializada en sistemas de pesaje. Atiende a
        industria, comercio y pequenas y medianas empresas con un enfoque directo: resolver en
        sitio, responder rapido y recomendar la mejor solucion aunque eso implique orientar al
        cliente hacia otra alternativa.
      </p>
      <p>
        La empresa combina experiencia tecnica, comunicacion sin burocracia y alianzas con
        entidades autorizadas para servicios de calibracion e inspeccion. El resultado es una
        operacion mas simple para clientes que necesitan precision, evidencia y continuidad.
      </p>
    </div>
  </div>
  <div class="section-inner proof-band" aria-label="Indicadores de confianza">
    {proof.map((item) => (
      <div>
        <strong>{item.value}</strong>
        <span>{item.label}</span>
      </div>
    ))}
  </div>
</section>

<style>
  .intro {
    background:
      radial-gradient(circle at top left, rgba(201, 37, 45, 0.22), transparent 32%),
      linear-gradient(135deg, #08111c, #10243a 58%, #08111c);
    color: var(--white);
  }

  .intro h2 {
    color: var(--white);
  }

  .intro__grid {
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.05fr);
    gap: clamp(34px, 6vw, 84px);
    align-items: start;
  }

  .intro__copy p {
    color: #dfe6ed;
    font-size: 1.08rem;
  }

  .proof-band {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    margin-top: clamp(36px, 5vw, 58px);
    border: 1px solid rgba(255, 255, 255, 0.16);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.06);
    overflow: hidden;
  }

  .proof-band div {
    min-height: 150px;
    padding: clamp(22px, 3vw, 34px);
    border-right: 1px solid rgba(255, 255, 255, 0.14);
  }

  .proof-band div:last-child {
    border-right: 0;
  }

  .proof-band strong {
    display: block;
    color: #ffffff;
    font-size: clamp(2.35rem, 4.4vw, 4.2rem);
    line-height: 0.95;
    white-space: nowrap;
  }

  .proof-band strong::after {
    content: "";
    display: block;
    width: 42px;
    height: 4px;
    margin: 18px 0 14px;
    border-radius: 999px;
    background: var(--red);
  }

  .proof-band span {
    display: block;
    max-width: 190px;
    color: #dce7f4;
    font-weight: 800;
  }

  @media (max-width: 860px) {
    .intro__grid {
      grid-template-columns: 1fr;
    }

    .proof-band {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .proof-band div:nth-child(2n) {
      border-right: 0;
    }
  }

  @media (max-width: 560px) {
    .proof-band {
      grid-template-columns: 1fr;
    }

    .proof-band div,
    .proof-band div:nth-child(2n) {
      border-right: 0;
      border-bottom: 1px solid rgba(255, 255, 255, 0.14);
    }

    .proof-band div:last-child {
      border-bottom: 0;
    }
  }
</style>
