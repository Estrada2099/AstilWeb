---
import { contact, services } from "../../data/site";
---

<section class="section contact" id="contacto">
  <div class="section-inner">
    <div class="contact__intro">
      <div>
        <p class="eyebrow">Contacto</p>
        <h2>Solicita atención para tu sistema de pesaje.</h2>
      </div>
      <p>
        Comparte el tipo de báscula, capacidad, ubicación y urgencia del servicio. Con esa
        información podemos orientarte con mayor precisión desde el primer contacto.
      </p>
    </div>

    <div class="contact__grid">
      <form
        class="contact-form"
        data-contact-form
        action="https://formspree.io/f/xjgjnrje"
        method="post"
      >
        <input type="hidden" name="_subject" value="Nueva solicitud desde Astil Básculas" />
        <input class="form-honeypot" type="text" name="_gotcha" tabindex="-1" autocomplete="off" />
        <label>
          Nombre
          <input type="text" name="nombre" autocomplete="name" required />
        </label>
        <label>
          Empresa
          <input type="text" name="empresa" autocomplete="organization" />
        </label>
        <label>
          Teléfono
          <input type="tel" name="telefono" autocomplete="tel" required />
        </label>
        <label>
          Correo
          <input type="email" name="email" autocomplete="email" />
        </label>
        <label class="form-full">
          Servicio requerido
          <select name="servicio">
            {services.map((service) => <option value={service.title}>{service.title}</option>)}
          </select>
        </label>
        <label class="form-full">
          Mensaje
          <textarea name="mensaje" rows="4" placeholder="Tipo de báscula, capacidad, ubicación y urgencia"></textarea>
        </label>
        <button class="button form-full" type="submit">Enviar solicitud</button>
        <p class="form-status form-full" data-form-status aria-live="polite"></p>
      </form>

      <aside class="contact-side" aria-label="Datos de contacto de Astil Básculas">
        <div class="contact-card">
          <strong>Astil Básculas</strong>
          <a href={contact.mapsUrl} target="_blank" rel="noreferrer">{contact.address}</a>
          <dl>
            <div>
              <dt>Horario</dt>
              {contact.hours.map((hour) => <dd>{hour}</dd>)}
            </div>
            <div>
              <dt>Oficina</dt>
              <dd><a href={contact.officePhoneHref}>{contact.officePhone}</a></dd>
            </div>
            <div>
              <dt>WhatsApp</dt>
              <dd>
                {contact.whatsapp.map((item, index) => (
                  <>
                    <a href={item.href} target="_blank" rel="noreferrer">{item.label}</a>
                    {index < contact.whatsapp.length - 1 && <span>/</span>}
                  </>
                ))}
              </dd>
            </div>
            <div>
              <dt>Correo</dt>
              <dd><a href={`mailto:${contact.email}`}>{contact.email}</a></dd>
            </div>
          </dl>
        </div>
        <iframe
          title="Ubicación de Astil Básculas en Google Maps"
          src={contact.mapsEmbed}
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
        ></iframe>
      </aside>
    </div>
  </div>
</section>

<div class="success-modal" data-success-modal hidden>
  <div class="success-modal__backdrop" data-success-close></div>
  <div
    class="success-modal__panel"
    role="dialog"
    aria-modal="true"
    aria-labelledby="success-modal-title"
  >
    <div class="success-modal__icon" aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="none">
        <path d="M20 6 9 17l-5-5" />
      </svg>
    </div>
    <p class="success-modal__eyebrow">Solicitud enviada</p>
    <h2 id="success-modal-title">Gracias<span data-success-name></span>.</h2>
    <p>Recibimos tu información. Te contactaremos lo antes posible para revisar tu necesidad de pesaje.</p>
    <button class="success-modal__button" type="button" data-success-close>Entendido</button>
  </div>
</div>

<script>
  const form = document.querySelector("[data-contact-form]");
  const status = document.querySelector("[data-form-status]");
  const successModal = document.querySelector("[data-success-modal]");
  const successName = document.querySelector("[data-success-name]");
  const successCloseButtons = document.querySelectorAll("[data-success-close]");

  if (form instanceof HTMLFormElement && status instanceof HTMLElement) {
    const submitButton = form.querySelector('button[type="submit"]');
    const defaultButtonText = submitButton?.textContent ?? "Enviar solicitud";
    const openSuccessModal = (nombre) => {
      if (!(successModal instanceof HTMLElement)) return;

      if (successName instanceof HTMLElement) {
        successName.textContent = nombre ? `, ${nombre}` : "";
      }

      successModal.hidden = false;
      document.body.classList.add("modal-open");
      successModal.querySelector("button")?.focus();
    };

    const closeSuccessModal = () => {
      if (!(successModal instanceof HTMLElement)) return;
      successModal.hidden = true;
      document.body.classList.remove("modal-open");
    };

    successCloseButtons.forEach((button) => {
      button.addEventListener("click", closeSuccessModal);
    });

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape") closeSuccessModal();
    });

    form.addEventListener("submit", async (event) => {
      event.preventDefault();

      if (!(submitButton instanceof HTMLButtonElement)) return;

      status.textContent = "";
      status.className = "form-status form-full";
      submitButton.disabled = true;
      submitButton.textContent = "Enviando...";

      try {
        const formData = new FormData(form);
        const nombre = String(formData.get("nombre") ?? "").trim();
        const response = await fetch(form.action, {
          method: "POST",
          body: formData,
          headers: {
            Accept: "application/json"
          }
        });

        if (!response.ok) {
          throw new Error("No se pudo enviar el formulario");
        }

        form.reset();
        openSuccessModal(nombre);
      } catch {
        status.textContent =
          "No pudimos enviar la solicitud. Intenta de nuevo o contáctanos por WhatsApp.";
        status.classList.add("is-error");
      } finally {
        submitButton.disabled = false;
        submitButton.textContent = defaultButtonText;
      }
    });
  }
</script>

<style>
  .contact {
    background: #101820;
    color: #ffffff;
  }

  .contact__intro {
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(280px, 0.72fr);
    gap: clamp(24px, 5vw, 72px);
    align-items: end;
    margin-bottom: 28px;
  }

  .contact__intro h2 {
    max-width: 680px;
    margin-bottom: 0;
    color: #ffffff;
    font-size: clamp(2rem, 4vw, 3.8rem);
  }

  .contact__intro > p {
    margin-bottom: 0;
    color: #dfe6ed;
    font-size: 1.06rem;
  }

  .contact__grid {
    display: grid;
    grid-template-columns: minmax(320px, 0.92fr) minmax(360px, 1.08fr);
    gap: 24px;
    align-items: stretch;
  }

  .contact-form {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    align-content: start;
    gap: 16px;
    padding: clamp(22px, 3vw, 30px);
    border-radius: 8px;
    background: #ffffff;
    color: var(--ink);
    box-shadow: 0 20px 50px rgba(8, 17, 28, 0.14);
  }

  .form-honeypot {
    position: absolute;
    left: -9999px;
    opacity: 0;
    pointer-events: none;
  }

  .contact-form label {
    display: grid;
    gap: 8px;
    color: #3e4a58;
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0;
  }

  .contact-form input,
  .contact-form select,
  .contact-form textarea {
    width: 100%;
    min-height: 46px;
    padding: 11px 12px;
    border: 1px solid #d7dee8;
    border-radius: 6px;
    background: #f8fafc;
    color: var(--ink);
    font: inherit;
    font-size: 0.95rem;
    font-weight: 500;
    outline: none;
    transition:
      border-color 0.18s ease,
      background-color 0.18s ease,
      box-shadow 0.18s ease;
  }

  .contact-form input:focus,
  .contact-form select:focus,
  .contact-form textarea:focus {
    border-color: #6d8197;
    background: #ffffff;
    box-shadow: 0 0 0 3px rgba(67, 95, 120, 0.12);
  }

  .contact-form textarea {
    min-height: 118px;
    resize: vertical;
  }

  .contact-form ::placeholder {
    color: #7a8795;
    font-weight: 500;
  }

  .form-full {
    grid-column: 1 / -1;
  }

  .contact-form button:disabled {
    cursor: wait;
    opacity: 0.72;
  }

  .form-status {
    display: none;
    margin: 0;
    padding: 11px 13px;
    border-radius: 6px;
    font-size: 0.9rem;
    font-weight: 700;
    line-height: 1.35;
  }

  .form-status.is-success,
  .form-status.is-error {
    display: block;
  }

  .form-status.is-success {
    border: 1px solid #cddfd9;
    background: #f3faf7;
    color: #155c4c;
  }

  .form-status.is-error {
    border: 1px solid #efd0d4;
    background: #fff7f7;
    color: var(--red-dark);
  }

  .success-modal[hidden] {
    display: none;
  }

  :global(body.modal-open) {
    overflow: hidden;
  }

  .success-modal {
    position: fixed;
    inset: 0;
    z-index: 80;
    display: grid;
    place-items: center;
    padding: 18px;
  }

  .success-modal__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(8, 17, 28, 0.68);
    backdrop-filter: blur(8px);
  }

  .success-modal__panel {
    position: relative;
    z-index: 1;
    display: grid;
    justify-items: center;
    width: min(430px, 100%);
    padding: 30px;
    border: 1px solid rgba(215, 222, 232, 0.9);
    border-radius: 8px;
    background: #ffffff;
    color: var(--ink);
    text-align: center;
    box-shadow: 0 28px 80px rgba(8, 17, 28, 0.28);
  }

  .success-modal__icon {
    display: grid;
    place-items: center;
    width: 68px;
    height: 68px;
    margin-bottom: 16px;
    border-radius: 999px;
    background: #e8f5f1;
    color: #137462;
  }

  .success-modal__icon svg {
    width: 34px;
    height: 34px;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 2.5;
  }

  .success-modal__eyebrow {
    margin-bottom: 8px;
    color: var(--red);
    font-size: 0.74rem;
    font-weight: 900;
    text-transform: uppercase;
  }

  .success-modal h2 {
    margin-bottom: 10px;
    font-size: clamp(1.7rem, 3vw, 2.2rem);
  }

  .success-modal__panel > p:last-of-type {
    max-width: 330px;
    margin-bottom: 20px;
    color: var(--muted);
    font-size: 0.98rem;
  }

  .success-modal__button {
    min-height: 42px;
    padding: 10px 18px;
    border: 0;
    border-radius: 6px;
    background: var(--ink);
    color: #ffffff;
    font: inherit;
    font-weight: 850;
    cursor: pointer;
  }

  .success-modal__button:hover {
    background: var(--red);
  }

  .contact-side {
    display: grid;
    grid-template-rows: auto minmax(260px, 1fr);
    gap: 16px;
    min-width: 0;
  }

  .contact-card {
    padding: 24px;
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 8px;
    background: #1d2730;
  }

  .contact-card strong,
  .contact-card a {
    display: block;
  }

  .contact-card strong {
    margin-bottom: 14px;
    color: #ffffff;
    font-size: 1.28rem;
  }

  .contact-card a {
    color: #edf4f2;
    text-decoration: none;
  }

  .contact-card dl {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 16px 22px;
    margin: 22px 0 0;
  }

  .contact-card dt {
    color: #ffffff;
    font-weight: 850;
  }

  .contact-card dd {
    margin: 4px 0 0;
    color: #dfe6ed;
  }

  .contact-card dd a,
  .contact-card dd span {
    display: inline-flex;
    margin-right: 5px;
  }

  iframe {
    width: 100%;
    min-height: 260px;
    border: 0;
    border-radius: 8px;
    background: #d7dde5;
  }

  @media (max-width: 980px) {
    .contact__intro,
    .contact__grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 620px) {
    .contact-form,
    .contact-card dl {
      grid-template-columns: 1fr;
    }
  }
</style>
