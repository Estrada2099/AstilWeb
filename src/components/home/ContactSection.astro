---
import { contact, services } from "../../data/site";
---

<section class="section contact" id="contacto">
  <div class="section-inner">
    <div class="contact__intro">
      <div>
        <p class="eyebrow">Contacto</p>
        <h2>Solicita atencion para tu sistema de pesaje.</h2>
      </div>
      <p>
        Comparte el tipo de bascula, capacidad, ubicacion y urgencia del servicio. Con esa
        informacion podemos orientarte con mayor precision desde el primer contacto.
      </p>
    </div>

    <div class="contact__grid">
      <form
        class="contact-form"
        action={`mailto:${contact.email}`}
        method="post"
        enctype="text/plain"
      >
        <label>
          Nombre
          <input type="text" name="nombre" autocomplete="name" required />
        </label>
        <label>
          Empresa
          <input type="text" name="empresa" autocomplete="organization" />
        </label>
        <label>
          Telefono
          <input type="tel" name="telefono" autocomplete="tel" required />
        </label>
        <label>
          Correo
          <input type="email" name="correo" autocomplete="email" />
        </label>
        <label class="form-full">
          Servicio requerido
          <select name="servicio">
            {services.map((service) => <option>{service.title}</option>)}
          </select>
        </label>
        <label class="form-full">
          Mensaje
          <textarea name="mensaje" rows="4" placeholder="Tipo de bascula, capacidad, ubicacion y urgencia"></textarea>
        </label>
        <button class="button form-full" type="submit">Enviar solicitud</button>
      </form>

      <aside class="contact-side" aria-label="Datos de contacto de Astil Basculas">
        <div class="contact-card">
          <strong>Astil Basculas</strong>
          <a href={contact.mapsUrl} target="_blank" rel="noreferrer">{contact.address}</a>
          <dl>
            <div>
              <dt>Horario</dt>
              {contact.hours.map((hour) => <dd>{hour}</dd>)}
            </div>
            <div>
              <dt>Oficina</dt>
              <dd><a href={contact.officePhoneHref}>{contact.officePhone}</a></dd>
            </div>
            <div>
              <dt>WhatsApp</dt>
              <dd>
                {contact.whatsapp.map((item, index) => (
                  <>
                    <a href={item.href} target="_blank" rel="noreferrer">{item.label}</a>
                    {index < contact.whatsapp.length - 1 && <span>/</span>}
                  </>
                ))}
              </dd>
            </div>
            <div>
              <dt>Correo</dt>
              <dd><a href={`mailto:${contact.email}`}>{contact.email}</a></dd>
            </div>
          </dl>
        </div>
        <iframe
          title="Ubicacion de Astil Basculas en Google Maps"
          src={contact.mapsEmbed}
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
        ></iframe>
      </aside>
    </div>
  </div>
</section>

<style>
  .contact {
    background: #101820;
    color: #ffffff;
  }

  .contact__intro {
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(280px, 0.72fr);
    gap: clamp(24px, 5vw, 72px);
    align-items: end;
    margin-bottom: 28px;
  }

  .contact__intro h2 {
    max-width: 680px;
    margin-bottom: 0;
    color: #ffffff;
    font-size: clamp(2rem, 4vw, 3.8rem);
  }

  .contact__intro > p {
    margin-bottom: 0;
    color: #dfe6ed;
    font-size: 1.06rem;
  }

  .contact__grid {
    display: grid;
    grid-template-columns: minmax(320px, 0.92fr) minmax(360px, 1.08fr);
    gap: 24px;
    align-items: stretch;
  }

  .contact-form {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    align-content: start;
    gap: 14px;
    padding: 22px;
    border-radius: 8px;
    background: #ffffff;
    color: var(--ink);
  }

  .contact-form label {
    display: grid;
    gap: 7px;
    color: #384553;
    font-size: 0.9rem;
    font-weight: 800;
  }

  .contact-form input,
  .contact-form select,
  .contact-form textarea {
    width: 100%;
    min-height: 44px;
    padding: 10px 12px;
    border: 1px solid #c8d1dc;
    border-radius: 6px;
    color: var(--ink);
    font: inherit;
  }

  .contact-form textarea {
    min-height: 118px;
    resize: vertical;
  }

  .form-full {
    grid-column: 1 / -1;
  }

  .contact-side {
    display: grid;
    grid-template-rows: auto minmax(260px, 1fr);
    gap: 16px;
    min-width: 0;
  }

  .contact-card {
    padding: 24px;
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 8px;
    background: #1d2730;
  }

  .contact-card strong,
  .contact-card a {
    display: block;
  }

  .contact-card strong {
    margin-bottom: 14px;
    color: #ffffff;
    font-size: 1.28rem;
  }

  .contact-card a {
    color: #edf4f2;
    text-decoration: none;
  }

  .contact-card dl {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 16px 22px;
    margin: 22px 0 0;
  }

  .contact-card dt {
    color: #ffffff;
    font-weight: 850;
  }

  .contact-card dd {
    margin: 4px 0 0;
    color: #dfe6ed;
  }

  .contact-card dd a,
  .contact-card dd span {
    display: inline-flex;
    margin-right: 5px;
  }

  iframe {
    width: 100%;
    min-height: 260px;
    border: 0;
    border-radius: 8px;
    background: #d7dde5;
  }

  @media (max-width: 980px) {
    .contact__intro,
    .contact__grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 620px) {
    .contact-form,
    .contact-card dl {
      grid-template-columns: 1fr;
    }
  }
</style>
