---
import { heroHighlights } from "../../data/site";
---

<section class="hero">
  <div class="hero__overlay">
    <div class="hero__content">
      <p class="hero__tag">
        <span aria-hidden="true"></span>
        Soluciones que pesan. Confianza que perdura.
      </p>
      <h1>Expertos en basculas industriales, enfocados en tu operacion.</h1>
      <p class="lead">
        Servicio tecnico, mantenimiento, calibracion, inspeccion y soluciones de pesaje para
        empresas que necesitan precision, confiabilidad y continuidad.
      </p>
      <div class="button-row">
        <a class="button" href="#servicios">Nuestros servicios</a>
        <a class="button secondary" href="#contacto">Hablemos</a>
      </div>
    </div>

    <div class="hero-highlights" aria-label="Beneficios principales">
      {heroHighlights.map((item) => (
        <article>
          <div class="highlight-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none">
              <path d="M12 3l7 4v5c0 4.5-2.8 7.8-7 9-4.2-1.2-7-4.5-7-9V7l7-4z" />
              <path d="M8.5 12.2l2.2 2.2 4.8-5" />
            </svg>
          </div>
          <div>
            <h2>{item.title}</h2>
            <p>{item.text}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: calc(100svh - 72px);
    max-height: calc(100svh - 72px);
    background:
      linear-gradient(90deg, rgba(6, 13, 23, 0.96) 0%, rgba(8, 17, 30, 0.9) 34%, rgba(8, 17, 30, 0.42) 68%, rgba(8, 17, 30, 0.76) 100%),
      linear-gradient(180deg, rgba(6, 13, 23, 0.1), rgba(6, 13, 23, 0.96)),
      url("/hero.png"),
      linear-gradient(120deg, #0b1728, #20364d);
    background-position: center;
    background-size: cover;
    color: #ffffff;
  }

  .hero__overlay {
    display: grid;
    grid-template-rows: auto auto;
    align-content: start;
    row-gap: clamp(42px, 7vh, 76px);
    min-height: inherit;
    max-height: inherit;
    padding: clamp(16px, 2.5vw, 30px) clamp(18px, 5vw, 72px) clamp(12px, 1.6vw, 18px);
  }

  .hero__content {
    align-self: start;
    padding-top: clamp(18px, 5vh, 48px);
    width: min(560px, 100%);
  }

  .hero__tag {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    max-width: 310px;
    margin-bottom: 9px;
    color: #ffffff;
    font-size: 0.72rem;
    font-weight: 900;
    line-height: 1.35;
    text-transform: uppercase;
  }

  .hero__tag span {
    width: 28px;
    height: 28px;
    border: 2px solid #2f7df6;
    border-radius: 8px;
    background:
      linear-gradient(135deg, transparent 44%, #2f7df6 45% 55%, transparent 56%),
      rgba(47, 125, 246, 0.12);
  }

  .hero h1 {
    max-width: 560px;
    margin-bottom: 10px;
    color: #ffffff;
    font-size: clamp(2rem, 3.65vw, 3.45rem);
  }

  .hero h1::after {
    content: "";
    display: block;
    width: 96px;
    height: 4px;
    margin-top: 10px;
    border-radius: 999px;
    background: linear-gradient(90deg, var(--red), #2f7df6);
  }

  .hero .lead {
    max-width: 540px;
    color: #dce7f4;
    font-size: clamp(0.94rem, 1.05vw, 1rem);
  }

  .hero .button-row {
    margin-top: 14px;
  }

  .hero .button {
    min-height: 40px;
  }

  .hero .button {
    border-color: #2f7df6;
    background: #2f7df6;
    box-shadow: 0 14px 30px rgba(47, 125, 246, 0.24);
  }

  .hero .button.secondary {
    border-color: rgba(255, 255, 255, 0.34);
    background: rgba(255, 255, 255, 0.08);
    color: #ffffff;
    box-shadow: none;
  }

  .hero-highlights {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0;
    margin-top: 0;
    border-top: 1px solid rgba(255, 255, 255, 0.15);
  }

  .hero-highlights article {
    display: grid;
    grid-template-columns: 30px minmax(0, 1fr);
    gap: 10px;
    min-height: 70px;
    padding: 12px 16px 4px 0;
    border-right: 1px solid rgba(255, 255, 255, 0.15);
  }

  .hero-highlights article:last-child {
    border-right: 0;
  }

  .highlight-icon {
    display: grid;
    place-items: center;
    width: 30px;
    height: 30px;
    border-radius: 10px;
    background: rgba(47, 125, 246, 0.14);
    color: #2f7df6;
  }

  .highlight-icon svg {
    width: 19px;
    height: 19px;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 1.7;
  }

  .hero-highlights h2 {
    margin-bottom: 5px;
    color: #ffffff;
    font-size: 0.84rem;
    line-height: 1.2;
  }

  .hero-highlights p {
    margin-bottom: 0;
    color: #aebccc;
    font-size: 0.76rem;
  }

  @media (max-width: 980px) {
    .hero-highlights {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .hero-highlights article:nth-child(2n) {
      border-right: 0;
    }
  }

  @media (max-width: 640px) {
    .hero {
      min-height: auto;
    }

    .hero__overlay {
      padding-top: 46px;
    }

    .hero-highlights {
      grid-template-columns: 1fr;
    }

    .hero-highlights article,
    .hero-highlights article:nth-child(2n) {
      border-right: 0;
      border-bottom: 1px solid rgba(255, 255, 255, 0.15);
    }

    .hero-highlights article:last-child {
      border-bottom: 0;
    }
  }
</style>
