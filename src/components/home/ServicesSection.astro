---
import { services } from "../../data/site";

const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) => `${base}${path.replace(/^\//, "")}`;
---

<section class="section services" id="servicios">
  <div class="section-inner">
    <div class="services-heading">
      <div>
        <p class="eyebrow">Servicios</p>
        <h2>Ocho frentes de servicio para mantener tu pesaje operativo.</h2>
      </div>
      <p class="lead">
        Atención técnica, cumplimiento, fabricación y tecnología para empresas que necesitan
        continuidad, evidencia y respuesta clara.
      </p>
    </div>
    <div class="service-grid">
      {services.map((service, index) => (
        <article class="service-card" tabindex="0">
          <div class="service-card__inner">
            <div class="service-card__face service-card__front">
              <div class="service-card__top">
                <span>{String(index + 1).padStart(2, "0")}</span>
              </div>
              <div class="service-card__center">
                <div class="service-icon">
                  <img src={withBase(service.icon)} alt="" loading="lazy" onerror="this.style.display='none'" />
                </div>
                <h3>{service.title}</h3>
              </div>
              <span class="service-card__hint" aria-label="Girar tarjeta">
                <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <path d="M17 2l4 4-4 4" />
                  <path d="M3 11V9a3 3 0 0 1 3-3h15" />
                  <path d="M7 22l-4-4 4-4" />
                  <path d="M21 13v2a3 3 0 0 1-3 3H3" />
                </svg>
              </span>
            </div>
            <div class="service-card__face service-card__back">
              <span>{String(index + 1).padStart(2, "0")}</span>
              <h3>{service.title}</h3>
              <p>{service.text}</p>
              <a class="service-card__button" href={"href" in service ? withBase(service.href) : "#contacto"}>
                Conocer más
              </a>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .services {
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.72), rgba(255, 255, 255, 0.32)),
      repeating-linear-gradient(90deg, rgba(67, 95, 120, 0.08) 0 1px, transparent 1px 96px),
      linear-gradient(135deg, #f7f9fc 0%, #edf3f8 46%, #e4ebf3 100%);
    border-top: 1px solid rgba(174, 188, 204, 0.5);
  }

  .services-heading {
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(280px, 0.55fr);
    gap: clamp(22px, 5vw, 72px);
    align-items: end;
    margin-bottom: clamp(28px, 4vw, 46px);
  }

  .services-heading h2 {
    max-width: 850px;
    margin-bottom: 0;
    color: var(--ink);
  }

  .services-heading .lead {
    position: relative;
    max-width: 520px;
    margin-bottom: 0;
    padding: 20px 0 0 22px;
    color: var(--muted);
    font-size: 1rem;
    border-left: 3px solid var(--red);
  }

  .services-heading .eyebrow {
    color: var(--red);
  }

  .service-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 16px;
  }

  .service-card {
    min-height: 260px;
    border: 0;
    border-radius: 8px;
    background: transparent;
    perspective: 1100px;
    outline: none;
  }

  .service-card__inner {
    position: relative;
    width: 100%;
    min-height: 260px;
    transition: transform 0.62s ease;
    transform-style: preserve-3d;
  }

  .service-card:hover .service-card__inner,
  .service-card:focus-within .service-card__inner,
  .service-card:focus .service-card__inner {
    transform: rotateY(180deg);
  }

  .service-card__face {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    overflow: hidden;
    padding: 22px;
    border: 1px solid rgba(174, 188, 204, 0.52);
    border-radius: 8px;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(246, 248, 251, 0.96)),
      radial-gradient(circle at top right, rgba(67, 95, 120, 0.1), transparent 38%),
      #ffffff;
    backface-visibility: hidden;
    box-shadow: 0 14px 30px rgba(8, 17, 28, 0.07);
  }

  .service-card__face::before {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    border-top: 3px solid transparent;
    border-image: linear-gradient(90deg, var(--red), var(--steel), var(--blue-dark)) 1;
  }

  .service-card__front {
    align-items: flex-start;
  }

  .service-card__top {
    display: flex;
    justify-content: flex-end;
    align-items: flex-start;
    width: 100%;
    gap: 16px;
  }

  .service-card__center {
    display: grid;
    place-items: center;
    width: 100%;
    min-height: 154px;
    text-align: center;
  }

  .service-card__front h3 {
    max-width: 250px;
    margin: 14px auto 0;
    font-size: 1.08rem;
    line-height: 1.14;
  }

  .service-card__hint {
    display: inline-grid;
    place-items: center;
    align-self: flex-end;
    width: 28px;
    height: 28px;
    margin: 0;
    border: 1px solid rgba(67, 95, 120, 0.22);
    border-radius: 999px;
    background: #eef2f6;
    color: var(--steel);
  }

  .service-card__hint svg {
    width: 16px;
    height: 16px;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 2;
  }

  .service-card__back {
    display: grid;
    grid-template-rows: auto auto minmax(0, 1fr) auto;
    gap: 8px;
    background:
      radial-gradient(circle at top right, rgba(47, 125, 246, 0.12), transparent 34%),
      linear-gradient(145deg, rgba(67, 95, 120, 0.18), transparent 42%),
      linear-gradient(135deg, #08111c, #102033 72%, #182d43);
    color: var(--white);
    transform: rotateY(180deg);
  }

  .service-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 138px;
    height: 138px;
  }

  .service-icon img {
    width: 136px;
    height: 136px;
    object-fit: contain;
  }

  .service-card__top span,
  .service-card__back > span {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 32px;
    border-radius: 999px;
    background: #eef2f6;
    color: var(--ink);
    font-weight: 900;
  }

  .service-card__back h3 {
    margin: 4px 0 0;
    color: var(--white);
    font-size: 1.08rem;
    line-height: 1.12;
  }

  .service-card__back p {
    min-height: 0;
    margin: 0;
    overflow: auto;
    color: #dfe6ed;
    font-size: 0.86rem;
    line-height: 1.42;
    scrollbar-width: thin;
  }

  .service-card__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 38px;
    margin-top: 4px;
    padding: 8px 14px;
    border: 1px solid rgba(255, 255, 255, 0.3);
    border-radius: 6px;
    background: #ffffff;
    color: var(--ink);
    font-weight: 850;
    text-decoration: none;
  }

  .service-card__button:hover {
    border-color: #ffffff;
    background: #eef4ff;
    color: var(--ink);
  }

  @media (max-width: 1100px) {
    .services-heading {
      grid-template-columns: 1fr;
      align-items: start;
    }

    .services-heading .lead {
      padding-top: 0;
    }

    .service-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 620px) {
    .service-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
