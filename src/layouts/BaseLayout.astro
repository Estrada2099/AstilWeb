---
import SiteFooter from "../components/SiteFooter.astro";
import SiteHeader from "../components/SiteHeader.astro";
import { contact } from "../data/site";

interface Props {
  title: string;
  description: string;
  keywords?: string;
  image?: string;
  canonical?: string;
}

const {
  title,
  description,
  keywords = "basculas industriales, sistemas de pesaje, mantenimiento de basculas, calibracion de basculas",
  image = "/astil-basculas-logo-horizontal.png",
  canonical = Astro.url.pathname
} = Astro.props;
const base = import.meta.env.BASE_URL;
const withBase = (path: string) => `${base}${path.replace(/^\//, "")}`;
const canonicalUrl = new URL(canonical, Astro.site ?? Astro.url).toString();
const imageUrl = new URL(image.startsWith("http") ? image : withBase(image), Astro.site ?? Astro.url).toString();
const structuredData = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  name: "Astil Basculas",
  description,
  image: imageUrl,
  url: canonicalUrl,
  telephone: "+52 56 1186 2291",
  email: contact.email,
  address: {
    "@type": "PostalAddress",
    streetAddress: "Calle Miguel Negrete 527",
    addressLocality: "Texcoco de Mora",
    addressRegion: "Estado de Mexico",
    postalCode: "56170",
    addressCountry: "MX"
  },
  openingHoursSpecification: [
    {
      "@type": "OpeningHoursSpecification",
      dayOfWeek: ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
      opens: "08:30",
      closes: "18:00"
    },
    {
      "@type": "OpeningHoursSpecification",
      dayOfWeek: "Saturday",
      opens: "09:00",
      closes: "14:00"
    }
  ],
  areaServed: ["Texcoco", "Estado de Mexico", "Ciudad de Mexico"],
  makesOffer: [
    "Mantenimiento de basculas",
    "Reparacion de basculas",
    "Calibracion de basculas",
    "Inspeccion de basculas",
    "Venta de basculas industriales",
    "Fabricacion de basculas",
    "Software para sistemas de pesaje"
  ]
};
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#101820" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href={withBase("/astil-basculas-logo-horizontal.png")} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="es_MX" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={imageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
    <title>{title}</title>
  </head>
  <body>
    <SiteHeader />
    <main>
      <slot />
    </main>
    <SiteFooter />
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light;
    --ink: #08111c;
    --muted: #546172;
    --line: #d5dde8;
    --paper: #f4f7fb;
    --white: #ffffff;
    --red: #d4212e;
    --red-dark: #a01824;
    --blue: #2f7df6;
    --blue-dark: #173e79;
    --steel: #435f78;
    --green: #137462;
    --gold: #c09338;
    --shadow: 0 20px 50px rgba(8, 17, 28, 0.14);
  }

  * {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    color: var(--ink);
    background: var(--paper);
    line-height: 1.5;
  }

  img {
    max-width: 100%;
    display: block;
  }

  a {
    color: inherit;
  }

  main {
    overflow: clip;
  }

  .section {
    padding: clamp(64px, 8vw, 108px) clamp(18px, 5vw, 72px);
    background: var(--white);
  }

  .section-inner {
    width: min(1180px, 100%);
    margin: 0 auto;
  }

  .eyebrow {
    margin: 0 0 10px;
    color: var(--red);
    font-size: 0.78rem;
    font-weight: 850;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  h1,
  h2,
  h3,
  p {
    margin-top: 0;
  }

  h1,
  h2,
  h3 {
    line-height: 1.05;
    letter-spacing: 0;
  }

  h1 {
    max-width: 920px;
    margin-bottom: 22px;
    font-size: clamp(2.75rem, 7vw, 6.4rem);
  }

  h2 {
    max-width: 780px;
    margin-bottom: 18px;
    font-size: clamp(2rem, 4vw, 4.2rem);
  }

  h3 {
    font-size: 1.16rem;
  }

  .lead {
    max-width: 760px;
    color: #384553;
    font-size: clamp(1.08rem, 2vw, 1.35rem);
  }

  .button-row {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 30px;
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 0 18px;
    border: 1px solid var(--ink);
    border-radius: 6px;
    background: linear-gradient(135deg, var(--ink), #172a3f);
    color: var(--white);
    font-weight: 800;
    text-decoration: none;
  }

  .button.secondary {
    background: var(--white);
    color: var(--ink);
  }

  .button:hover {
    transform: translateY(-1px);
  }

</style>
